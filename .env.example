# Copy this file to `.env.local` and fill in values from your Supabase project settings.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key

# --- Supabase CLI: push migrations to Production (or any remote DB) ---
# Prerequisite: install CLI (https://supabase.com/docs/guides/cli), then:
#   1) supabase login
#   2) supabase link --project-ref <YOUR_PROJECT_REF>
#   3) supabase db push --linked
#
# Optional CI: non-interactive login
# SUPABASE_ACCESS_TOKEN=sbp_your_personal_access_token
#
# Optional reference (used by link; not read automatically by push)
SUPABASE_PROJECT_REF=your-project-ref
