# Copy to .env.local for local dev. Add the same keys in Vercel → Project Settings → Environment Variables.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
NEXT_PUBLIC_ADSENSE_CLIENT=
# Optional AdSense ad unit slot IDs (numeric strings from AdSense UI)
NEXT_PUBLIC_ADSENSE_SLOT_TOP=
NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR=
NEXT_PUBLIC_ADSENSE_SLOT_CONTENT=
NEXT_PUBLIC_ADSENSE_SLOT_FOOTER=
